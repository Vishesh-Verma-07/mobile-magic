    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "prettier": "^3.7.4",
    "turbo": "^2.8.20",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.1.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "lucide-react": "^1.7.0",
    "prisma": "^7.5.0"
  },
  "module": "index.ts",
  "type": "module"
